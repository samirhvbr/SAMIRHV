{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment_modelo": "Usando opusplan: Opus 4.8 pra planejar, Sonnet 4.6 pra executar",
  "model": "opusplan",
  "_comment_effort": "Max + adaptive thinking off = sempre raciocinio profundo",
  "effortLevel": "max",
  "env": {
    "CLAUDE_CODE_SUBAGENT_MODEL": "sonnet",
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "claude-opus-4-8",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "claude-sonnet-4-6"
  },
  "permissions": {
    "_comment": "Permissões do projeto - Laravel/Blue3",
    "defaultMode": "plan",
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(php artisan about:*)",
      "Bash(php artisan route:list:*)",
      "Bash(php artisan migrate:status:*)",
      "Bash(php artisan view:clear:*)",
      "Bash(php artisan config:clear:*)",
      "Bash(php artisan cache:clear:*)",
      "Bash(php artisan route:clear:*)",
      "Bash(php artisan optimize:clear:*)",
      "Bash(php artisan tinker --execute:*)",
      "Bash(php artisan test:*)",
      "Bash(php artisan make:*)",
      "Bash(php -l:*)",
      "Bash(composer validate:*)",
      "Bash(composer show:*)",
      "Bash(composer install:*)",
      "Bash(composer dump-autoload:*)",
      "Bash(node -c:*)",
      "Bash(npm run dev:*)",
      "Bash(npm run build:*)",
      "Bash(npm install:*)",
      "Bash(./vendor/bin/pint:*)",
      "Bash(./vendor/bin/phpstan:*)",
      "Bash(./vendor/bin/pest:*)",
      "Bash(./vendor/bin/phpunit:*)"
    ],
    "deny": [
      "Read(./storage/oauth-*.key)",
      "Read(./storage/*.pem)",
      "Read(./auth.json)",
      "Bash(rm -rf:*)",
      "Bash(rm -rf /:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -fd:*)",
      "Bash(php artisan migrate:fresh:*)",
      "Bash(php artisan migrate:reset:*)",
      "Bash(php artisan db:wipe:*)",
      "Bash(mysql:*)",
      "Bash(mariadb:*)",
      "Bash(curl * | sh:*)",
      "Bash(curl * | bash:*)",
      "Bash(wget * | sh:*)"
    ],
    "ask": [
      "Bash(sudo:*)",
      "Bash(git push:*)",
      "Bash(php artisan migrate:*)",
      "Bash(composer require:*)",
      "Bash(composer update:*)",
      "Bash(npm install --save:*)",
      "Bash(mysqldump:*)",
      "Bash(mariadb-dump:*)"
    ]
  }
}