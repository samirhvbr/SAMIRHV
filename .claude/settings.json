{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment_perfil": "PERFIL OPUS-ONLY — Opus 4.8 em tudo, janela 1M explicita via sufixo [1m] no model. NAO adicionar CLAUDE_CODE_DISABLE_1M_CONTEXT aqui: e ela que derruba a janela pra 200K. effortLevel maximo aceito em arquivo e 'xhigh'; 'max' so por sessao (/effort max ou CLAUDE_CODE_EFFORT_LEVEL=max no env).",
  "model": "opus[1m]",
  "effortLevel": "xhigh",
  "env": {
    "CLAUDE_CODE_SUBAGENT_MODEL": "opus",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "claude-opus-4-8"
  },
  "permissions": {
    "_comment": "Permissões do projeto - Laravel/Blue3",
    "defaultMode": "plan",
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(php artisan about:*)",
      "Bash(php artisan route:list:*)",
      "Bash(php artisan migrate:status:*)",
      "Bash(php artisan view:clear:*)",
      "Bash(php artisan config:clear:*)",
      "Bash(php artisan cache:clear:*)",
      "Bash(php artisan route:clear:*)",
      "Bash(php artisan optimize:clear:*)",
      "Bash(php artisan tinker --execute:*)",
      "Bash(php artisan test:*)",
      "Bash(php artisan make:*)",
      "Bash(php -l:*)",
      "Bash(composer validate:*)",
      "Bash(composer show:*)",
      "Bash(composer install:*)",
      "Bash(composer dump-autoload:*)",
      "Bash(node -c:*)",
      "Bash(npm run dev:*)",
      "Bash(npm run build:*)",
      "Bash(npm install:*)",
      "Bash(./vendor/bin/pint:*)",
      "Bash(./vendor/bin/phpstan:*)",
      "Bash(./vendor/bin/pest:*)",
      "Bash(./vendor/bin/phpunit:*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./storage/oauth-*.key)",
      "Read(./storage/*.pem)",
      "Read(./auth.json)",
      "Bash(php artisan migrate:fresh:*)",
      "Bash(php artisan migrate:reset:*)",
      "Bash(php artisan db:wipe:*)",
      "Bash(mysql:*)",
      "Bash(mariadb:*)",
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push * --force*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -fd:*)",
      "Bash(curl * | sh:*)",
      "Bash(curl * | bash:*)",
      "Bash(wget * | sh:*)",
      "Bash(wget * | bash:*)"
    ],
    "ask": [
      "Bash(sudo:*)",
      "Bash(php artisan migrate:*)",
      "Bash(composer require:*)",
      "Bash(composer update:*)",
      "Bash(npm install --save:*)",
      "Bash(mysqldump:*)",
      "Bash(mariadb-dump:*)"
    ]
  }
}
